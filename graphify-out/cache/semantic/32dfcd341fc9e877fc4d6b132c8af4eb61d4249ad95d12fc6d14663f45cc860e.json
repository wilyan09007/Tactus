{"nodes": [{"id": "docs_09_assembly_checklist_doc", "label": "Assembly checklist + bring-up (staged go/no-go gates)", "file_type": "document", "source_file": "docs/09-assembly-checklist.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Build in staged order with a go/no-go gate per stage; biggest risk is build time, so prove a small slice end-to-end before scaling."}, {"id": "docs_09_assembly_checklist_stage1_audio_path", "label": "Stage 1 \u2014 prove audio path before any soldering (speaker-test -c8)", "file_type": "concept", "source_file": "docs/09-assembly-checklist.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "speaker-test -c8 confirms all 8 channels map to the 4 jacks per Vantec; do not solder until every Vantec maps cleanly; fall back to a Sabrent dongle for a misbehaving jack."}, {"id": "docs_09_assembly_checklist_stage2_gut_tone_test", "label": "Stage 2 \u2014 gut + tone-test each amp (12 channels buzz)", "file_type": "concept", "source_file": "docs/09-assembly-checklist.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Gut each SK473 keeping its 2 KHD drivers, solder each on its own isolated 2-wire pair, tone-test so all 12 channels buzz; replace dead boards from the spare SK473."}, {"id": "docs_09_assembly_checklist_stage4_chord_stress_test", "label": "Stage 4 \u2014 chord stress test (fire all 12 at once)", "file_type": "concept", "source_file": "docs/09-assembly-checklist.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Firing all 12 at felt gain is a worst-case stress check; real playback is a sequential strum with <=2 drivers active (~2-3 W). Gate: no brown-out, no cut-outs."}, {"id": "docs_09_assembly_checklist_stage5_mount_couple", "label": "Stage 5 \u2014 mount + couple (6 strings on back, 6 fret-zones on torso)", "file_type": "concept", "source_file": "docs/09-assembly-checklist.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Mount actuators 6 strings on back + 6 fret-zones on torso with VHB + rigid backer, service loops and garment anchors so no actuator bears wire weight; each site clearly felt and secure under arm movement."}, {"id": "docs_09_assembly_checklist_stage6_software_bringup", "label": "Stage 6 \u2014 software bring-up (channel map, renderer, AI engine, coach)", "file_type": "concept", "source_file": "docs/09-assembly-checklist.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "channel_map.json must match the wiring table; renderer plays a known (string, fret) to the correct body site; AI engine does webcam+mic transcription + vision overlay; coach loop end-to-end on one phrase."}], "edges": [{"source": "docs_09_assembly_checklist_doc", "target": "docs_09_assembly_checklist_stage1_audio_path", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/09-assembly-checklist.md", "source_location": null, "weight": 1.0}, {"source": "docs_09_assembly_checklist_doc", "target": "docs_09_assembly_checklist_stage2_gut_tone_test", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/09-assembly-checklist.md", "source_location": null, "weight": 1.0}, {"source": "docs_09_assembly_checklist_doc", "target": "docs_09_assembly_checklist_stage4_chord_stress_test", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/09-assembly-checklist.md", "source_location": null, "weight": 1.0}, {"source": "docs_09_assembly_checklist_doc", "target": "docs_09_assembly_checklist_stage5_mount_couple", "relation": "references", "confidence": "EXTRACTED", "confidence_sc