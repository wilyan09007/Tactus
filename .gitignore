# local agent / editor
.claude/
.DS_Store
__pycache__/
*.pyc
.venv/
venv/

# raw capture media — keep manifest.jsonl, drop heavy A/V
data/raw/**/*.wav
data/raw/**/*.mp4
data/raw/**/*.mov
data/raw/**/*.webm

# offline-analysis outputs (regenerated by software/ai/analysis/run_pipeline.py)
data/analysis/

# graphify machine-specific pointers (absolute local paths, auto-regenerated)
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/cache/
graphify-out/.graphify_labels.json
graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/
.gstack/

# big untracked scaffolds / exports — not Tactus core, keep out of git + graphify
openui-app/
ui-assets/

# ML model weights (auto-downloaded by the vision backend; large)
*.pt
weights/
# vision backend test fixtures / annotated outputs (regenerable)
software/ai/vision/*.jpg
software/ai/vision/*_annotated.png
software/ai/vision/selftest_out.png
